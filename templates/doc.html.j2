{% extends "base.html.j2" %}

{% block title %}{{ doc_id }}{% endblock %}

{% block content %}
<p><a id="back-link" href="{{ url_for('index') }}">&larr; Back to search</a></p>
<h1>{{ doc_id }}</h1>
<div class="doc-body">{{ text }}</div>

<script>
    if (document.referrer) {
        try {
            const ref = new URL(document.referrer);
            if (ref.origin === window.location.origin) {
                document.getElementById("back-link").href = document.referrer;
            }
        } catch (_) {}
    }
</script>
{% endblock %}